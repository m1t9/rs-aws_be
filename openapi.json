{
  "openapi": "3.0.0",
  "info": {
    "title": "Product and Import Service API",
    "version": "1.0.0",
    "description": "API for retrieving products and generating import upload links"
  },
  "paths": {
    "/products": {
      "servers": [
        {
          "url": "https://82g1vt6ce6.execute-api.us-east-1.amazonaws.com/development/"
        }
      ],
      "get": {
        "summary": "Get all products",
        "operationId": "getProductsList",
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a product",
        "operationId": "createProduct",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductWithCount"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/products/{productId}": {
      "servers": [
        {
          "url": "https://82g1vt6ce6.execute-api.us-east-1.amazonaws.com/development/"
        }
      ],
      "get": {
        "summary": "Get product by ID",
        "operationId": "getProductsById",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the product"
          }
        ],
        "responses": {
          "200": {
            "description": "Product found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Bad request (missing productId)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/import": {
      "servers": [
        {
          "url": "https://zp6lrxx0ic.execute-api.us-east-1.amazonaws.com/development/"
        }
      ],
      "get": {
        "summary": "Get a signed upload URL for CSV import",
        "operationId": "importProductsFile",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File name to upload into the uploaded/ folder"
          }
        ],
        "responses": {
          "200": {
            "description": "Signed URL for uploading a CSV file",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request (missing name)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "7567ec4b-b10c-48c5-9345-fc73348a80a1"
          },
          "title": {
            "type": "string",
            "example": "Eco-Friendly Notebook"
          },
          "description": {
            "type": "string",
            "example": "Eco-friendly notebook made from recycled paper, perfect for notes and sketches."
          },
          "price": {
            "type": "number",
            "example": 15
          }
        }
      },
      "ProductWithCount": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "7567ec4b-b10c-48c5-9445-fc73c48a80a2"
          },
          "title": {
            "type": "string",
            "example": "Ceramic Coffee Mug"
          },
          "description": {
            "type": "string",
            "example": "Stylish ceramic mug, microwave and dishwasher safe, ideal for coffee or tea."
          },
          "price": {
            "type": "number",
            "example": 23
          },
          "count": {
            "type": "integer",
            "example": 8
          }
        }
      },
      "CreateProductRequest": {
        "type": "object",
        "required": ["title", "price"],
        "properties": {
          "title": {
            "type": "string",
            "example": "USB Flash Drive 32GB"
          },
          "description": {
            "type": "string",
            "example": "Reliable 32GB USB flash drive for fast and secure data storage."
          },
          "price": {
            "type": "number",
            "example": 15
          },
          "count": {
            "type": "integer",
            "example": 4
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Not Found"
          }
        }
      }
    }
  }
}